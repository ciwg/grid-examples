{
  "manifest_version": 3,
  "name": "Ex5 Operational Browser Embodiment",
  "version": "1.0.0",
  "description": "Chrome/Chromium native-messaging bridge for the ex5 direct browser embodiment.",
  "key": "",
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
